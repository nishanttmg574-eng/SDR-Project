# Copy this file to .env and fill in the values.

# Anthropic API key — required for AI scoring and Call prep features.
# Get one at https://console.anthropic.com (a $5 credit is plenty for beta).
# Starts with "sk-ant-". The rest of the app works without a key.
ANTHROPIC_API_KEY=

# Optional: override the dev-server port if 3000 is already in use.
# Used like `PORT=3001 npm run dev`. Uncomment to make it the default.
# PORT=3000
